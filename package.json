{
  "name": "wisopen",
  "version": "0.1.0",
  "private": true,
  "description": "Wisopen — voice dictation desktop app (Wispr Flow analog)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "vitest run backend",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 || true",
    "dev": "npm --workspace apps/desktop run dev",
    "build:mac": "npm --workspace apps/desktop run build:mac",
    "build:win": "npm --workspace apps/desktop run build:win"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
