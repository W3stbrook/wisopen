# Wisopen provider configuration for edge functions.
# Copy to `.env` (gitignored). SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY are auto-injected by the runtime — do NOT set them here.
#
# The whole app runs end-to-end with the defaults below (mock) and ZERO real keys.
# To use a real provider: set its *_PROVIDER, add the key(s), restart functions.

# ---- provider selection ----
STT_PROVIDER=mock            # aws-transcribe | openai | mock
LLM_PROVIDER=mock            # openai-compatible | bedrock | mock

# ---- LLM: OpenAI-compatible (covers OpenAI AND Tensorix) ----
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1   # or https://api.tensorix.ai/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini                     # or e.g. z-ai/glm-5.1 (Tensorix)

# ---- LLM: AWS Bedrock (Converse) ----
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20240620-v1:0

# ---- STT: OpenAI (buffered, gpt-4o-transcribe) ----
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-transcribe

# ---- STT: AWS Transcribe (reuses AWS_* above) ----
# (no extra keys; region + credentials from AWS_* above)
